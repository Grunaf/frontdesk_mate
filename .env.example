# Copy to .env.local and fill in values.
#
# Vercel / pilot hostel (required minimum):
#   NEXT_PUBLIC_SUPABASE_URL, NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY, SUPABASE_SECRET_KEY
#   ADMIN_SECRET, GUEST_SESSION_SECRET, RECEPTION_SESSION_SECRET
#   DATABASE_URL (if build runs city-pack DB scripts)
# Do not rotate GUEST/RECEPTION/ADMIN secrets after guest PINs or desk PIN are issued
# without re-issuing access or resetting desk PIN (PIN hashes use these secrets).

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=
# Supabase → Settings → API → Publishable key (sb_publishable_...)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Supabase → Settings → API → Secret key (sb_secret_...) — server only, NEVER NEXT_PUBLIC_
# Required for /admin tenant save, tenant-assets upload, guest_stays (reception).
# Legacy alias also supported: SUPABASE_SERVICE_ROLE_KEY (set one, not both needed).
SUPABASE_SECRET_KEY=

# Supabase Storage bucket for admin tenant images (default: tenant-assets)
# SUPABASE_TENANT_ASSETS_BUCKET=tenant-assets

# Postgres URI for automatic migrations (`npm run dev` / `npm run db:migrate`)
# Supabase → Connect → Session pooler → URI (port 5432)
DATABASE_URL=
# Vercel deploy: Build Command `npm run build:vercel` (no city-pack DB checks at build time).
# Local pre-release gate: `npm run build` (validate-v3 + parity when DATABASE_URL is set).
# Optional escape hatch: SKIP_CITY_PACK_DB=1 skips city-pack DB scripts only.

# Tenant slug — local dev only (flat app.localhost). Do not set on Vercel; prod uses hostname.
NEXT_PUBLIC_TENANT_SLUG=default

# Admin panel (/admin) — sign in once; session cookie lasts 7 days
ADMIN_SECRET=

# Guest session cookie signing (prod: set dedicated value; dev may fall back to ADMIN_SECRET)
GUEST_SESSION_SECRET=

# Reception desk session + desk PIN HMAC (prod: dedicated value; dev may fall back to ADMIN_SECRET)
RECEPTION_SESSION_SECRET=

# Dev panel (/dev-panel) — optional; falls back to ADMIN_SECRET
# DEV_PANEL_SECRET=

# Optional
# PostHog — omit NEXT_PUBLIC_POSTHOG_KEY to disable client analytics
# PostHog → Project settings → Project API key (phc_...)
NEXT_PUBLIC_POSTHOG_KEY=
# Ingest host (default when unset: https://eu.i.posthog.com)
# NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
NEXT_PUBLIC_MAX_FILE_SIZE_MB=100
# Frontdesk Master booking base URL (default: https://book.frontdeskmate.com/{propertySlug})
# NEXT_PUBLIC_FRONTDESK_MASTER_BOOKING_BASE_URL=https://book.frontdeskmate.com
# Force day/night UI while developing: day | night (omit for real clock)
# NEXT_PUBLIC_NIGHT_MODE_OVERRIDE=day
# Public hostname for tenant links (no protocol). Local: localhost:3000 — Vercel prod: your apex, e.g. staysync.cc
# NEXT_PUBLIC_BASE_DOMAIN=localhost:3000
# NEXT_PUBLIC_SITE_URL=https://staysync.cc

LOCALISATION_FILES_SRC="/src/shared/i18n/"
