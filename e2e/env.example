# Copy to e2e/env.local and fill in (e2e/env.local is gitignored).
# Used by Playwright smoke tests — one place for all test credentials.

# --- App base ---
# Host without protocol (matches NEXT_PUBLIC_BASE_DOMAIN)
E2E_BASE_DOMAIN=localhost:3000

# flat = http://app.localhost:3000/... (tenant from NEXT_PUBLIC_TENANT_SLUG on dev server)
# subdomain = http://{slug}.app.localhost:3000/... (production-like)
E2E_URL_MODE=flat

# Tenant under test (must exist in DB or match dev fallback)
E2E_TENANT_SLUG=vega

# Guest app locale segment
E2E_LOCALE=en

# Expected city pack on tenant (for admin/city-pack smoke assertions)
E2E_CITY_PACK_ID=sarajevo

# --- Admin (/admin) ---
# Same value as ADMIN_SECRET in .env.local
E2E_ADMIN_PASSWORD=

# --- Guest check-in ---
# 6-digit PIN created in reception desk or admin guest stay
E2E_GUEST_PIN=

# Optional: full magic-link URL if you prefer link flow over PIN
# E2E_GUEST_MAGIC_LINK=http://vega.app.localhost:3000/en/welcome?token=...

# --- Reception desk (optional) ---
# E2E_RECEPTION_DESK_PIN=

# --- Smoke timeouts (ms, optional) ---
# E2E_NAV_TIMEOUT=15000
