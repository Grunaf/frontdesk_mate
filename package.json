{
  "name": "frontdesk_mate",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/migrate-db.js --quiet && next dev",
    "dev:next": "next dev",
    "build:vercel": "node scripts/validate-i18n.js && next build",
    "build": "npm run city-pack:validate-v3 && npm run city-pack:parity && npm run build:vercel",
    "db:migrate": "node scripts/migrate-db.js",
    "db:migrate:status": "node scripts/migrate-db.js --status",
    "db:baseline": "node scripts/migrate-db.js --baseline",
    "city-pack:migrate-v3": "node scripts/migrate-city-pack-places-v3.js --dry-run",
    "city-pack:migrate-v3:apply": "node scripts/migrate-city-pack-places-v3.js --apply",
    "city-pack:migrate-routes": "node scripts/migrate-city-pack-routes.js --dry-run",
    "city-pack:migrate-routes:apply": "node scripts/migrate-city-pack-routes.js --apply",
    "city-pack:export-routes": "CITY_PACK_EXPORT_ROUTES=1 vitest run src/entities/city-pack/lib/exportRouteSeedFixtures.test.ts",
    "city-pack:validate-v3": "node scripts/validate-city-pack-places-v3.js",
    "city-pack:parity": "node scripts/verify-city-pack-db-parity.js",
    "validate-i18n": "node scripts/validate-i18n.js",
    "validate-i18n:strict": "node scripts/validate-i18n.js --strict",
    "sync-i18n": "node scripts/sync-i18n.js && node scripts/validate-i18n.js --strict",
    "start": "next start",
    "test": "vitest run",
    "smoke": "node scripts/run-smoke.js",
    "smoke:ui": "node scripts/run-smoke.js --ui",
    "smoke:install": "playwright install chromium",
    "smoke:report": "playwright show-report",
    "snapshot": "node scripts/generate-snapshot.js",
    "lint": "eslint",
    "lint:fsd": "steiger ./src",
    "format:check": "prettier --check \"src/**/*.{js,jsx,ts,tsx,json,css}\"",
    "format:fix": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json,css}\"",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@ai-sdk/openai": "^4.0.8",
    "@hugeicons/core-free-icons": "^4.1.4",
    "@hugeicons/react": "^1.1.6",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.106.2",
    "ai": "^7.0.15",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "embla-carousel-react": "^8.6.0",
    "lucide-react": "^1.17.0",
    "next": "^16.2.6",
    "next-intl": "^4.13.0",
    "postgres": "^3.4.9",
    "posthog-js": "^1.393.0",
    "qrcode": "^1.5.4",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.6",
    "server-only": "^0.0.1",
    "shadcn": "^4.8.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "web-push": "^3.6.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@feature-sliced/steiger-plugin": "^0.6.0",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/web-push": "^3.6.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "patch-package": "^8.0.1",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "steiger": "^0.5.13",
    "tailwindcss": "^4",
    "typescript": "^6.0.3",
    "vitest": "^2.1.8"
  }
}
